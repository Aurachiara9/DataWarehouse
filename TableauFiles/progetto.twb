        <calculation class='tableau' formula='CASE [product_category_name_english]&#13;&#10;    WHEN &apos;agro industry and commerce&apos; THEN &apos;Tools &amp; Garden 🛠️🪴&apos;&#13;&#10;    WHEN &apos;air conditioning&apos; THEN &apos;Home &amp; Living 🏠&apos;&#13;&#10;    WHEN &apos;art&apos; THEN &apos;Books &amp; Entertainment 📚🎸🎨&apos;&#13;&#10;    WHEN &apos;arts and craftmanship&apos; THEN &apos;Books &amp; Entertainment 📚🎸🎨&apos;&#13;&#10;    WHEN &apos;audio&apos; THEN &apos;Electronics 💻&apos;&#13;&#10;    WHEN &apos;auto&apos; THEN &apos;Automotive 🚗&apos;&#13;&#10;    WHEN &apos;baby&apos; THEN &apos;Sports, Hobbies &amp; Toys⚽&apos;&#13;&#10;    WHEN &apos;bed bath table&apos; THEN &apos;Home &amp; Living 🏠&apos;&#13;&#10;    WHEN &apos;books general interest&apos; THEN &apos;Books &amp; Entertainment 📚🎸🎨&apos;&#13;&#10;    WHEN &apos;books imported&apos; THEN &apos;Books &amp; Entertainment 📚🎸🎨&apos;&#13;&#10;    WHEN &apos;books technical&apos; THEN &apos;Books &amp; Entertainment 📚🎸🎨&apos;&#13;&#10;    WHEN &apos;cds dvds musicals&apos; THEN &apos;Books &amp; Entertainment 📚🎸🎨&apos;&#13;&#10;    WHEN &apos;christmas supplies&apos; THEN &apos;Sports, Hobbies &amp; Toys⚽&apos;&#13;&#10;    WHEN &apos;cine photo&apos; THEN &apos;Electronics 💻&apos;&#13;&#10;    WHEN &apos;computers&apos; THEN &apos;Electronics 💻&apos;&#13;&#10;    WHEN &apos;computers accessories&apos; THEN &apos;Electronics 💻&apos;&#13;&#10;    WHEN &apos;consoles games&apos; THEN &apos;Sports, Hobbies &amp; Toys⚽&apos;&#13;&#10;    WHEN &apos;construction tools construction&apos; THEN &apos;Tools &amp; Garden 🛠️🪴&apos;&#13;&#10;    WHEN &apos;construction tools lights&apos; THEN &apos;Tools &amp; Garden 🛠️🪴&apos;&#13;&#10;    WHEN &apos;construction tools safety&apos; THEN &apos;Tools &amp; Garden 🛠️🪴&apos;&#13;&#10;    WHEN &apos;cool stuff&apos; THEN &apos;Sports, Hobbies &amp; Toys⚽&apos;&#13;&#10;    WHEN &apos;costruction tools garden&apos; THEN &apos;Tools &amp; Garden 🛠️🪴&apos;&#13;&#10;    WHEN &apos;costruction tools tools&apos; THEN &apos;Tools &amp; Garden 🛠️🪴&apos;&#13;&#10;    WHEN &apos;diapers and hygiene&apos; THEN &apos;Health &amp; Beauty 💄&apos;&#13;&#10;    WHEN &apos;drinks&apos; THEN &apos;Food &amp; Drink 🍕🍷&apos;&#13;&#10;    WHEN &apos;dvds blu ray&apos; THEN &apos;Books &amp; Entertainment 📚🎸🎨&apos;&#13;&#10;    WHEN &apos;electronics&apos; THEN &apos;Electronics 💻&apos;&#13;&#10;    WHEN &apos;fashio female clothing&apos; THEN &apos;Fashion &amp; Goods 👗&apos;&#13;&#10;    WHEN &apos;fashion bags accessories&apos; THEN &apos;Fashion &amp; Goods 👗&apos;&#13;&#10;    WHEN &apos;fashion childrens clothes&apos; THEN &apos;Fashion &amp; Goods 👗&apos;&#13;&#10;    WHEN &apos;fashion male clothing&apos; THEN &apos;Fashion &amp; Goods 👗&apos;&#13;&#10;    WHEN &apos;fashion shoes&apos; THEN &apos;Fashion &amp; Goods 👗&apos;&#13;&#10;    WHEN &apos;fashion sport&apos; THEN &apos;Fashion &amp; Goods 👗&apos;&#13;&#10;    WHEN &apos;fashion underwear beach&apos; THEN &apos;Fashion &amp; Goods 👗&apos;&#13;&#10;    WHEN &apos;fixed telephony&apos; THEN &apos;Electronics 💻&apos;&#13;&#10;    WHEN &apos;flowers&apos; THEN &apos;Tools &amp; Garden 🛠️🪴&apos;&#13;&#10;    WHEN &apos;food&apos; THEN &apos;Food &amp; Drink 🍕🍷&apos;&#13;&#10;    WHEN &apos;food drink&apos; THEN &apos;Food &amp; Drink 🍕🍷&apos;&#13;&#10;    WHEN &apos;furniture bedroom&apos; THEN &apos;Home &amp; Living 🏠&apos;&#13;&#10;    WHEN &apos;furniture decor&apos; THEN &apos;Home &amp; Living 🏠&apos;&#13;&#10;    WHEN &apos;furniture living room&apos; THEN &apos;Home &amp; Living 🏠&apos;&#13;&#10;    WHEN &apos;furniture mattress and upholstery&apos; THEN &apos;Home &amp; Living 🏠&apos;&#13;&#10;    WHEN &apos;garden tools&apos; THEN &apos;Tools &amp; Garden 🛠️🪴&apos;&#13;&#10;    WHEN &apos;health beauty&apos; THEN &apos;Health &amp; Beauty 💄&apos;&#13;&#10;    WHEN &apos;home appliances&apos; THEN &apos;Home &amp; Living 🏠&apos;&#13;&#10;    WHEN &apos;home confort&apos; THEN &apos;Home &amp; Living 🏠&apos;&#13;&#10;    WHEN &apos;home construction&apos; THEN &apos;Tools &amp; Garden 🛠️🪴&apos;&#13;&#10;    WHEN &apos;housewares&apos; THEN &apos;Home &amp; Living 🏠&apos;&#13;&#10;    WHEN &apos;industry commerce and business&apos; THEN &apos;Business &amp; Office 💼📊&apos;&#13;&#10;    WHEN &apos;kitchen dining laundry garden furniture&apos; THEN &apos;Home &amp; Living 🏠&apos;&#13;&#10;    WHEN &apos;la cuisine&apos; THEN &apos;Home &amp; Living 🏠&apos;&#13;&#10;    WHEN &apos;luggage accessories&apos; THEN &apos;Fashion &amp; Accessories👗&apos;&#13;&#10;    WHEN &apos;market place&apos; THEN &apos;Business &amp; Office 💼📊&apos;&#13;&#10;    WHEN &apos;music&apos; THEN &apos;Books &amp; Entertainment 📚🎸🎨&apos;&#13;&#10;    WHEN &apos;musical instruments&apos; THEN &apos;Books &amp; Entertainment 📚🎸🎨&apos;&#13;&#10;    WHEN &apos;office furniture&apos; THEN &apos;Business &amp; Office 💼📊&apos;&#13;&#10;    WHEN &apos;party supplies&apos; THEN &apos;Sports, Hobbies &amp; Toys⚽&apos;&#13;&#10;    WHEN &apos;pc gamer&apos; THEN &apos;Electronics 💻&apos;&#13;&#10;    WHEN &apos;perfumery&apos; THEN &apos;Health &amp; Beauty 💄&apos;&#13;&#10;    WHEN &apos;pet shop&apos; THEN &apos;Sports, Hobbies &amp; Toys⚽&apos;&#13;&#10;    WHEN &apos;portable kitchen and food preparators&apos; THEN &apos;Home &amp; Living 🏠&apos;&#13;&#10;    WHEN &apos;security and services&apos; THEN &apos;Business &amp; Office 💼📊&apos;&#13;&#10;    WHEN &apos;signaling and security&apos; THEN &apos;Tools &amp; Garden 🛠️🪴&apos;&#13;&#10;    WHEN &apos;small appliances&apos; THEN &apos;Home &amp; Living 🏠&apos;&#13;&#10;    WHEN &apos;small appliances home oven and coffee&apos; THEN &apos;Home &amp; Living 🏠&apos;&#13;&#10;    WHEN &apos;sports leisure&apos; THEN &apos;Sports, Hobbies &amp; Toys⚽&apos;&#13;&#10;    WHEN &apos;stationery&apos; THEN &apos;Business &amp; Office 💼📊&apos;&#13;&#10;    WHEN &apos;tablets printing image&apos; THEN &apos;Electronics 💻&apos;&#13;&#10;    WHEN &apos;telephony&apos; THEN &apos;Electronics 💻&apos;&#13;&#10;    WHEN &apos;toys&apos; THEN &apos;Sports, Hobbies &amp; Toys⚽&apos;&#13;&#10;    WHEN &apos;watches gifts&apos; THEN &apos;Fashion &amp; Goods 👗&apos;&#13;&#10;    ELSE &apos;Other 📦&apos;&#13;&#10;END' />
      </column>
      <column caption='Metrica Dinamica Tree Chart' datatype='real' name='[Calculation_1906838102179846]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parametro 2]&#13;&#10;    WHEN &apos;Value&apos; THEN SUM([price])&#13;&#10;    WHEN &apos;Quantity&apos; THEN COUNT([__tableau_internal_object_id__].[FactTable.csv_A8BF420123374C76AABBDD49F0BE9E40])&#13;&#10;END' />
      </column>
      <column caption='Metrica Dinamica Chart' datatype='real' name='[Calculation_1906838113206280]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parametro 2]&#13;&#10;    WHEN &apos;Value&apos; THEN SUM([price])&#13;&#10;    WHEN &apos;Quantity&apos; THEN COUNT([__tableau_internal_object_id__].[FactTable.csv_A8BF420123374C76AABBDD49F0BE9E40])&#13;&#10;END' />
      </column>
      <column caption='Titolo Area Chart' datatype='string' name='[Calculation_1906838116139018]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parametro 2]&#13;&#10;    WHEN &apos;Value&apos; THEN &apos;VALUE TREND - The value of goods has increased sharply over the years!&apos;&#13;&#10;    WHEN &apos;Quantity&apos; THEN &apos;SALES TREND - In just three years, purchases in Brasil on the Olist e-commerce platform have skyrocketed going from a few hundred (315 items) to nearly sixty thousand!&apos;&#13;&#10;END' />
      </column>
      <column caption='Sottotitolo Area Chart' datatype='string' name='[Calculation_1906838118027275]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parametro 2]&#13;&#10;    WHEN &apos;Value&apos; THEN &apos;mettiiiii&apos;&#13;&#10;    WHEN &apos;Quantity&apos; THEN &apos;Most of the items were sold in São Paulo (SP), Rio de Janeiro (RJ) and Minas Gerais (MG).&apos;&#13;&#10;END' />
      </column>
      <column caption='Titolo Tree Chart' datatype='string' name='[Calculation_1906838122172428]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parametro 2]&#13;&#10;    WHEN &apos;Value&apos; THEN &apos;Percentage value of items sold by category&apos;&#13;&#10;    WHEN &apos;Quantity&apos; THEN &apos;Percentage of items sold by category&apos;&#13;&#10;END' />
      </column>
      <column caption='Cleaned Macro Category' datatype='string' name='[Calculation_1906838190858253]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Top 6 categories] THEN [Calculation_1906838065106944]&#13;&#10;ELSE &apos;Other📚🎸🎨🚗🍕&apos;&#13;&#10;END' />
      </column>
      <column caption='Posizione Categoria' datatype='integer' name='[Calculation_1906838224474128]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_UNIQUE([Calculation_1906838113206280], &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Valore Fisso Categoria' datatype='real' name='[Calculation_1906838228774929]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_1906838065106944] : SUM([price]) }' />
      </column>
      <column caption='Metrica per Set' datatype='real' name='[Calculation_1906838232727571]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parametro 2]&#13;&#10;    WHEN &apos;Value&apos; THEN [price]&#13;&#10;    WHEN &apos;Quantity&apos; THEN 1&#13;&#10;END' />
      </column>
      <column caption='State (Top 3 + Other)' datatype='string' name='[Calculation_2180339203440640]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Top 3 States] THEN [customer_state]&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
      <column caption='Mese Stringa' datatype='string' name='[Calculation_2373306913951744]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [order_purchase_month]&#13;&#10;    WHEN 1 THEN &quot;Gen&quot;&#13;&#10;    WHEN 2 THEN &quot;Feb&quot;&#13;&#10;    WHEN 3 THEN &quot;Mar&quot;&#13;&#10;    WHEN 4 THEN &quot;Apr&quot;&#13;&#10;    WHEN 5 THEN &quot;Mag&quot;&#13;&#10;    WHEN 6 THEN &quot;Giu&quot;&#13;&#10;    WHEN 7 THEN &quot;Lug&quot;&#13;&#10;    WHEN 8 THEN &quot;Ago&quot;&#13;&#10;    WHEN 9 THEN &quot;Set&quot;&#13;&#10;    WHEN 10 THEN &quot;Ott&quot;&#13;&#10;    WHEN 11 THEN &quot;Nov&quot;&#13;&#10;    WHEN 12 THEN &quot;Dic&quot;&#13;&#10;END' />
      </column>
      <column caption='Shipping ratio (%)' datatype='real' name='[Calculation_2373306935099393]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([freight_value] / ([price] + [freight_value]))' />
      </column>
      <column caption='Colore Sopra/Sotto Media' datatype='boolean' name='[Calculation_2373306944405506]' role='measure' type='nominal'>
        <calculation class='tableau' formula='AVG([Calculation_2373306935099393]) &gt;= TOTAL(AVG([Calculation_2373306935099393]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Ritardo_Giorni' datatype='integer' name='[Calculation_2373307002580997]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF DATEDIFF(&apos;day&apos;,&#13;&#10;   [order_estimated_delivery_date],&#13;&#10;   [order_delivered_customer_date]) &gt; 0&#13;&#10;THEN&#13;&#10;   DATEDIFF(&apos;day&apos;,&#13;&#10;      [order_estimated_delivery_date],&#13;&#10;      [order_delivered_customer_date])&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='Is_Delay' datatype='real' name='[Calculation_2373307009306630]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(IF [Calculation_2373307002580997] &gt; 0 THEN 1.0 ELSE 0 END) * 100' />
      </column>
      <column caption='Delivery Status' datatype='string' name='[Calculation_2373307045322768]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATETRUNC(&apos;day&apos;, [order_delivered_customer_date]) &lt; DATETRUNC(&apos;day&apos;, [order_estimated_delivery_date]) THEN &#13;&#10;    &quot;In advance&quot;&#13;&#10;ELSEIF DATETRUNC(&apos;day&apos;, [order_delivered_customer_date]) = DATETRUNC(&apos;day&apos;, [order_estimated_delivery_date]) THEN &#13;&#10;    &quot;On time&quot;&#13;&#10;ELSE &#13;&#10;    &quot;Late&quot;&#13;&#10;END' />
      </column>
      <column caption='Titolo Customer Map' datatype='string' name='[Calculation_2535485596348416]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parametro 2]&#13;&#10;    WHEN &apos;Value&apos; THEN &apos;Geographical distribution of revenue&apos;&#13;&#10;    WHEN &apos;Quantity&apos; THEN &apos;Geographical distribution of items purchased&apos;&#13;&#10;END' />
      </column>
      <column caption='Dinamic Map Legend' datatype='string' name='[Calculation_2535485598531585]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parametro 2]&#13;&#10;    WHEN &apos;Value&apos; THEN &apos;Exact value of revenue&apos;&#13;&#10;    WHEN &apos;Quantity&apos; THEN &apos;Number of items sold&apos;&#13;&#10;END' />
      </column>
      <column caption='DateDiffOrderShip' datatype='integer' name='[Calculation_2599256921714688]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,[order_purchase_timestamp], [order_delivered_carrier_date])' />
      </column>
      <column caption='% Cosegne non in ritardo' datatype='real' default-format='p0.00%' name='[Calculation_2881006577377280]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Calculation_2373307045322768] = &quot;In advance&quot; OR [Calculation_2373307045322768] = &quot;On time&quot; THEN 1 ELSE 0 END) &#13;&#10;/ &#13;&#10;COUNT([ID_order_delivered_customer_date])' />
      </column>
